{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash rd-workflow/scripts/hooks/session_start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash rd-workflow/scripts/hooks/pre_commit_review_gate.sh"
          },
          {
            "type": "command",
            "command": "bash rd-workflow/scripts/hooks/pre_commit_archive_gate.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash rd-workflow/scripts/hooks/implementation_gate.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash rd-workflow/scripts/hooks/implementation_gate.sh"
          }
        ]
      }
    ]
  }
}
